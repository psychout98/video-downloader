# ─────────────────────────────────────────────────────
# Media Downloader -- Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# ── Required API Keys ───────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here
REAL_DEBRID_API_KEY=your_real_debrid_api_key_here

# ── Primary Media Dirs (fast NVMe) ──────────────────
# New downloads land here.
MOVIES_DIR=C:\Users\noaha\Media\Movies
TV_DIR=C:\Users\noaha\Media\TV Shows
ANIME_DIR=C:\Users\noaha\Media\Anime
DOWNLOADS_DIR=C:\Users\noaha\Media\Downloads\.staging

# ── Archive Media Dirs (SATA) ───────────────────────
# Watched content is automatically moved here.
MOVIES_DIR_ARCHIVE=D:\Media\Movies
TV_DIR_ARCHIVE=D:\Media\TV Shows
ANIME_DIR_ARCHIVE=D:\Media\Anime

# ── Watch Detection ─────────────────────────────────
# Fraction of runtime considered "watched" (0.0 – 1.0)
WATCH_THRESHOLD=0.85

# ── MPC-BE ──────────────────────────────────────────
MPC_BE_URL=http://127.0.0.1:13579
MPC_BE_EXE=C:\Program Files\MPC-BE x64\mpc-be64.exe

# ── Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Downloads ───────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=2
RD_POLL_INTERVAL=30
