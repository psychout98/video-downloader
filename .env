# ─────────────────────────────────────────────────────
# Media Downloader -- Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────

# TMDB API key (free) -- https://www.themoviedb.org/settings/api
TMDB_API_KEY=7a6b69edec44fe48df3d5a2be162dd7f

# Real-Debrid API key -- https://real-debrid.com/apitoken
REAL_DEBRID_API_KEY=QB5UEQ6YGML7FC7F3QONCQJXSJYEQ3JMFVMWICSKDPH6ZLIIYKJQ

# ── Security ──────────────────────────────────────────

# Bearer token for the /api/download webhook (used by Siri Shortcut).
# Set this to any long random string. Leave as "change-me" to disable auth.
SECRET_KEY=change-me

# ── Primary Media Dirs (NVMe -- new downloads land here) ──────────────
# Defaults to C:\Users\<YourUsername>\Media\...
# Override if your NVMe drive is different.

MOVIES_DIR=C:\Users\noaha\Media\Movies
TV_DIR=C:\Users\noaha\Media\TV Shows
ANIME_DIR=C:\Users\noaha\Media\Anime
DOWNLOADS_DIR=C:\Users\noaha\Media\Downloads\.staging

# Central folder for all poster images (kept separate from video files)
# Named after the title folder: Posters\Inception (2010).jpg, Posters\Breaking Bad.jpg
POSTERS_DIR=C:\Users\noaha\Media\Posters

# ── Archive Media Dirs (SATA -- watched content is moved here) ─────────
# After you finish watching something, it's automatically moved here.

MOVIES_DIR_ARCHIVE=D:\Media\Movies
TV_DIR_ARCHIVE=D:\Media\TV Shows
ANIME_DIR_ARCHIVE=D:\Media\Anime

# ── Watch Detection ────────────────────────────────────────────────────
# Fraction of runtime that must be played before a file is archived.
# 0.85 = 85% of the video must be watched. Adjust if credits are skipped.
# WATCH_THRESHOLD=0.85

# ── MPC-BE Web Interface ───────────────────────────────────────────────
# Enable in MPC-BE: View -> Options -> Player -> Web Interface -> Listen on port 13579
MPC_BE_URL=http://127.0.0.1:13579

# Full path to MPC-BE executable — used to launch it automatically when closed
# Adjust if you installed the 32-bit version or to a custom location
MPC_BE_EXE=C:\Program Files\MPC-BE x64\mpc-be64.exe

# ── Server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Download Settings ──────────────────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=2
RD_POLL_INTERVAL=30
