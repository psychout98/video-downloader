# ─────────────────────────────────────────────────────
# Media Downloader -- Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# ── Required API Keys ───────────────────────────────
TMDB_API_KEY=7a6b69edec44fe48df3d5a2be162dd7f
REAL_DEBRID_API_KEY=KVMPAY67C7HZBGTVXN2KLNONOA6TQ4UETE227I5NVAPGKGUCGP4Q

# ── Primary Media Dirs (fast NVMe) ──────────────────
# New downloads land here.
MOVIES_DIR=~\Media\Movies
TV_DIR=~\Media\TV Shows
ANIME_DIR=~\Media\Anime
DOWNLOADS_DIR=~\Media\Downloads\.staging

# ── Archive Media Dirs (SATA) ───────────────────────
# Watched content is automatically moved here.
MOVIES_DIR_ARCHIVE=~\MediaArchive\Movies
TV_DIR_ARCHIVE=~\MediaArchive\TV Shows
ANIME_DIR_ARCHIVE=~\MediaArchive\Anime

# ── Watch Detection ─────────────────────────────────
# Fraction of runtime considered "watched" (0.0 – 1.0)
WATCH_THRESHOLD=0.85

# ── MPC-BE ──────────────────────────────────────────
MPC_BE_URL=http://127.0.0.1:13579
MPC_BE_EXE=C:\Program Files\MPC-BE x64\mpc-be64.exe

# ── Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Downloads ───────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=2
RD_POLL_INTERVAL=30
